FROM node:22-alpine

# Upgrade all Alpine packages to patch known CVEs in the base image
RUN apk update && apk upgrade --no-cache

WORKDIR /app

# Copy package files and Prisma schema before npm ci so the postinstall
# hook ("prisma generate") can run. A dummy DATABASE_URL is needed because
# prisma.config.ts reads it at load time (no real DB required for generate).
COPY package*.json ./
COPY prisma ./prisma
COPY prisma.config.ts ./
RUN DATABASE_URL="postgresql://dummy:dummy@localhost:5432/dummy" npm ci

# Expose Next.js dev port
EXPOSE 3001

# Start Next.js in dev mode (hot reload enabled)
# Re-generate the Prisma client AFTER the source volume is mounted so the
# in-container client always matches the live schema, then sync the DB.
CMD ["sh", "-c", "npx prisma generate && npx prisma db push --accept-data-loss && npm run dev"]
