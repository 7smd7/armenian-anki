FROM node:22-alpine

# Upgrade all Alpine packages to patch known CVEs in the base image
RUN apk update && apk upgrade --no-cache

WORKDIR /app

# Copy package files and install all dependencies (including devDeps)
COPY package*.json ./
RUN npm ci

# Generate Prisma client (source will be mounted over this, but we need
# the generated client available before the volume mount kicks in)
COPY prisma ./prisma
COPY prisma.config.ts ./
# prisma.config.ts requires DATABASE_URL to load, but generate doesn't need
# a real DB — pass a dummy value so the config file resolves without error.
RUN DATABASE_URL="postgresql://dummy:dummy@localhost:5432/dummy" npx prisma generate

# Expose Next.js dev port
EXPOSE 3001

# Start Next.js in dev mode (hot reload enabled)
CMD ["sh", "-c", "npx prisma db push && npm run dev"]
