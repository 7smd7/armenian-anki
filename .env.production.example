# ================================================
# Armenian Anki - Production Environment Variables
# ================================================
# 
# Copy this file and fill in real values for production deployment
# DO NOT commit actual secrets to git
# Use your platform's secrets manager (Vercel, Railway, GitHub Secrets, etc.)

# ========================================
# DATABASE CONFIGURATION
# ========================================
# Database service credentials used by docker-compose postgres service
DB_USER="anki_user"
DB_PASSWORD="changeMe123!"
DB_NAME="armenian_anki"

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# Example: postgresql://anki_user:SecurePass123!@db.example.com:5432/armenian_anki
DATABASE_URL="postgresql://anki_user:changeMe123!@postgres:5432/armenian_anki"

# Application port (Coolify/server default uses 3001 to avoid 3000 conflicts)
APP_PORT="3001"

# ========================================
# NEXTAUTH CONFIGURATION
# ========================================
# Full URL of your application (used for OAuth redirects)
# CRITICAL: Must match authorized redirect URI in Google OAuth settings
# Examples: https://yourdomain.com, https://app.yourdomain.com
NEXTAUTH_URL="https://yourdomain.com"

# Secret key for NextAuth session encryption
# Generate with: openssl rand -base64 32
# Must be at least 32 characters, cryptographically random
NEXTAUTH_SECRET="your_nextauth_secret_generated_with_openssl_rand"


# Optional: Giphy API key for showing illustrative GIFs on the back of cards
# Sign up at https://developers.giphy.com/ and place your API key here.
# The key is exposed to the client, so use a key with appropriate limits.
NEXT_PUBLIC_GIPHY_API_KEY=""


# ========================================
# GOOGLE OAUTH CONFIGURATION
# ========================================
# OAuth credentials from Google Cloud Console
# 1. Go to https://console.cloud.google.com
# 2. Create OAuth 2.0 Web Application credentials
# 3. Add authorized redirect URI: https://yourdomain.com/api/auth/callback/google
# 4. Copy Client ID and Secret below

GOOGLE_CLIENT_ID="123456789-your_client_id_here.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your_secret_key_here_keep_private"

# ========================================
# NODE ENVIRONMENT
# ========================================
# Set to 'production' for deployment, 'development' for local testing
NODE_ENV="production"

# ================================================
# OPTIONAL CONFIGURATION
# ================================================

# Enable debug logging (set to 'true' for troubleshooting)
# NEXTAUTH_DEBUG="false"

# ================================================
# DEPLOYMENT PLATFORM SPECIFIC
# ================================================

# For Vercel deployment:
# - Set these environment variables in Vercel Project Settings → Environment Variables
# - Restart deployment after changing variables

# For Railway deployment:
# - Set these in Project → Variables (encrypted storage)
# - Redeploy to apply changes

# For self-hosted/VPS:
# - Add to /opt/armenian-anki/.env on your server
# - Restart systemd service: sudo systemctl restart armenian-anki

# For Docker deployment:
# - Set in docker-compose.yml environment section OR
# - Create .env file in project root before docker-compose up
